<span style="font-size:9px;color:var(--text3)">${p.team}</span></div></td><td style="color:var(--win)">${p.wins}</td><td style="color:var(--text3)">${p.losses}</td><td>${g>0?wp+'%':'—'}</td><td>${ppg}</td><td class="${diff>0?'diff-pos':diff<0?'diff-neg':''}">${g>0?(diff>0?'+':'')+diff:'—'}</td></tr>`;
}).join('')}</tbody></table></div>`;
});
_g('player-stats-content').innerHTML=html;
}
function renderCheckIn(){
const total=36;
const paid=checkedIn.size;
const unpaid=total-paid;
const pot=paid*10;
const payout80=Math.round(pot*0.80);
const payout85=Math.round(pot*0.85);
_g('ci-stats').innerHTML=`
<div class="ci-stat"><div class="ci-stat-val">${total}</div><div class="ci-stat-lbl">REGISTERED</div></div><div class="ci-stat"><div class="ci-stat-val" style="color:var(--win)">${paid}</div><div class="ci-stat-lbl">CHECKED IN</div></div><div class="ci-stat"><div class="ci-stat-val" style="color:var(--lose)">${unpaid}</div><div class="ci-stat-lbl">UNPAID</div></div><div class="ci-stat"><div class="ci-stat-val" style="color:var(--orange)">$${pot}</div><div class="ci-stat-lbl">POT</div></div>`;
const allPlayers=[];
TEAMS.forEach((t,ti)=>{
t.players.forEach((p,pi)=>{
const key=`${ti}-${pi}`;
const fullName=TEAMS[ti].players[pi];
allPlayers.push({key,shortName:p,fullName,team:t.name,color:t.color,tier:pi,checked:checkedIn.has(key)});
});
});
let filtered=allPlayers;
if(ciFilterMode==='paid') filtered=allPlayers.filter(p=>p.checked);
if(ciFilterMode==='unpaid') filtered=allPlayers.filter(p=>!p.checked);
const tierLabels=['T1','T2','T3','T4'];
const tierCols=['#E8571A','#D4A017','#2EA87E','#4A9ED6'];
_g('ci-list').innerHTML=filtered.map(p=>`
<div class="ci-row${p.checked?' checked':''}" onclick="toggleCheckin('${p.key}')"><div class="ci-check"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div style="flex:1"><div style="display:flex;align-items:center;gap:8px"><span class="ci-name">${p.fullName}</span><span class="ci-tier" style="background:${tierCols[p.tier]}22;color:${tierCols[p.tier]}">${tierLabels[p.tier]}</span></div><div class="ci-team" style="color:${p.color}">${p.team}</div></div><span class="ci-paid-lbl">PAID $10</span></div>`).join('');
const holdback=80;
const weeklyPayout=Math.max(0,pot-holdback);
let seriesTotalPaid=0,seriesWeeks=0;
try{const sd=JSON.parse(localStorage.getItem('jp_series')||'{}');seriesTotalPaid=sd.totalPaid||0;seriesWeeks=sd.weeks||0;}catch(e){}
const seriesPool=seriesWeeks*holdback;
_g('payout-box').innerHTML=`<div class="payout-title">PRIZE POT — WEEK 1</div><div class="payout-grid"><div class="payout-item"><strong>$${pot}</strong><span>TODAY'S POT</span></div><div class="payout-item"><strong style="color:var(--win)">$${weeklyPayout}</strong><span>PAID OUT TODAY</span></div><div class="payout-item"><strong style="color:var(--t2)">$${holdback}</strong><span>HELD FOR SERIES</span></div><div class="payout-item"><strong style="color:var(--t4)">$${seriesPool}</strong><span>SERIES POOL (${seriesWeeks} wks)</span></div></div><div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr;gap:8px"><div class="payout-item"><strong>$${seriesTotalPaid}</strong><span>TOTAL PAID OUT (series)</span></div><div class="payout-item"><strong style="color:var(--orange)">$${seriesPool}</strong><span>END-OF-SERIES AWARD POT</span></div></div><div style="font-size:9px;color:var(--text3);margin-top:8px;letter-spacing:.06em">$10/player · $80 held back each week for end-of-series awards</div>`;
}
function toggleCheckin(key){
if(checkedIn.has(key)) checkedIn.delete(key);
else checkedIn.add(key);
renderCheckIn();
saveState();
}
function ciFilter(mode,btn){
ciFilterMode=mode;
_qa('.ci-filter button').forEach(b=>b.classList.remove('on'));
btn.classList.add('on');
renderCheckIn();
}
function toggleAdmin(){
adminMode=!adminMode;
_g('admin-btn').classList.toggle('on',adminMode);
_qa('.admin-only').forEach(el=>el.style.display=adminMode?'':'none');
if(!adminMode&&_g('tab-checkin').classList.contains('on')){
showTab('schedule');
}
}
function showTab(name){
_qa('.panel').forEach(p=>p.classList.remove('on'));
_qa('.tab').forEach(t=>t.classList.remove('on'));
_g('tab-'+name).classList.add('on');
const map={schedule:0,mygames:1,myteam:2,standings:3,players:4,checkin:5};
const tabs=_qa('.tab');
if(tabs[map[name]]) tabs[map[name]].classList.add('on');
if(name==='standings') renderStandings();
if(name==='players') renderPlayerStats();
if(name==='checkin') renderCheckIn();
}
function manualSave(){
const obj ={
v: 1,
week: 'W1',
ts: new Date().toISOString(),
scores: scores.map(r=>r.map(s=>({a:s.a,b:s.b}))),
checkedIn: Array.from(checkedIn),
activeRound
};
const blob = new Blob([JSON.stringify(obj,null,2)],{type:'application/json'});
const url = URL.createObjectURL(blob);
const a = _ce('a');
const dateStr = new Date().toLocaleDateString('en-US',{month:'short',day:'numeric'}).replace(' ','-');
a.href = url;
a.download = 'jp-squads-w1-'+dateStr+'.json';
a.click();
URL.revokeObjectURL(url);
showToast('✓ Saved — keep that file safe!');
}
function manualLoad(input){
const file = input.files[0];
if(!file) return;
const reader = new FileReader();
reader.onload = e =>{
try{
const data = JSON.parse(e.target.result);
if(!data.scores) throw new Error('Invalid file');
data.scores.forEach((r,ri)=>{
r.forEach((s,ci)=>{
if(scores[ri]&&scores[ri][ci]){
scores[ri][ci].a = s.a;
scores[ri][ci].b = s.b;
}
});
});
if(data.checkedIn){checkedIn.clear();data.checkedIn.forEach(k=>checkedIn.add(k));}
if(typeof data.activeRound==='number') activeRound = data.activeRound;
renderSchedule();
renderStandings();
renderPlayerStats();
renderMyTeam();
if(_g('tab-checkin').classList.contains('on')) renderCheckIn();
saveState();
showToast('✓ Scores loaded from file');
}catch(err){
showToast('✗ Could not read file');
}
input.value='';
};
reader.readAsText(file);
}
function showToast(msg){
const t = _g('save-toast');
t.textContent = msg;
const isErr = msg.startsWith('✗');
t.style.borderColor = isErr ? 'var(--lose)' : 'var(--win)';
t.style.color = isErr ? 'var(--lose)' : 'var(--win)';
t.classList.add('show');
setTimeout(()=>t.classList.remove('show'),2800);
}
const TAB_ORDER=['schedule','mygames','myteam','standings','players'];
let _swipeX=null;
_q('.app').addEventListener('touchstart',e=>{_swipeX=e.touches[0].clientX;},{passive:true});
_q('.app').addEventListener('touchend',e=>{
if(_swipeX===null) return;
const dx=e.changedTouches[0].clientX-_swipeX;
_swipeX=null;
if(Math.abs(dx)<60) return;
const cur=_q('.panel.on')?.id?.replace('tab-','');
const i=TAB_ORDER.indexOf(cur);
if(i<0) return;
const next=dx<0?TAB_ORDER[i+1]:TAB_ORDER[i-1];
if(next) showTab(next);
},{passive:true});
function haptic(style='light'){
try{
if(navigator.vibrate) navigator.vibrate(style==='light'?10:30);
}catch(e){}
}
function toggleLock(r,c){
const key=r+'-'+c;
scoreLocks[key]=!scoreLocks[key];
haptic('light');
renderSchedule();
saveState();
}
function checkAutoAdvance(){
if(activeRound>=6){
const allDone=SCHEDULE.every((_,r)=>isRoundDone(r));
if(allDone) setTimeout(()=>showRecapPrompt(),600);
return;
}
if(!isRoundDone(activeRound)) return;
const next=activeRound+1;
const banner=_g('advance-banner');
if(banner) banner.remove();
const div=_ce('div');
div.className='auto-advance-banner';
div.id='advance-banner';
div.innerHTML=`<span>Round ${activeRound+1}complete!</span><button class="advance-btn" onclick="goNextRound()">START ROUND ${next+1}→</button>`;
_g('courts-grid').before(div);
haptic('medium');
}
function goNextRound(){
const b=_g('advance-banner');
if(b) b.remove();
activeRound++;
renderSchedule();
saveState();
}
function showRecapPrompt(){
_g('recap-confirm').style.display='block';
_g('recap-results').style.display='none';
_g('recap-overlay').classList.add('show');
}
function finalizeEvent(){
manualSave();
_g('recap-confirm').style.display='none';
_g('recap-results').style.display='block';
buildRecap();
}
function buildRecap(){
const sorted=getAllStats();
const top3=sorted.slice(0,3);
const rankColors=['#D4A017','#9E9A94','#C87533'];
const rankLabels=['🥇 1st','🥈 2nd','🥉 3rd'];
_g('recap-podium').innerHTML=top3.map((t,i)=>`
<div class="podium-item" style="border-color:${rankColors[i]}22"><div class="podium-rank" style="color:${rankColors[i]}">${rankLabels[i]}</div><div style="width:3px;height:3px;border-radius:50%;background:${t.color};margin:6px auto"></div><div class="podium-name" style="color:${t.color}">${t.name}</div><div class="podium-wl">${t.wins}W · ${t.losses}L</div><div style="font-size:10px;color:${t.diff>0?'var(--win)':'var(--text3)'};margin-top:2px">${t.diff>0?'+':''}${t.diff}pts</div></div>`).join('');
}
buildPlayerSelect();
buildTeamSelect();
renderSchedule();
renderStandings();
renderPlayerStats();
if(window._savedPlayer){
const sel=_g('mygames-select');
if(sel){sel.value=window._savedPlayer;renderMyGames();}
}
function clearAllScores(){
if(!confirm('Clear ALL scores? This cannot be undone.')) return;
scores.forEach(r=>r.forEach(s=>{s.a=null;s.b=null;}));
Object.keys(scoreLocks).forEach(k=>delete scoreLocks[k]);
const banner=document.getElementById('advance-banner');
if(banner) banner.remove();
renderSchedule();
renderStandings();
renderPlayerStats();
renderMyTeam();
saveState();
showToast('✓ All scores cleared');
}
</script></body></html>
